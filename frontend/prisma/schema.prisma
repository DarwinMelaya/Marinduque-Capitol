// Prisma manages schema/migrations for Supabase Postgres.
// Runtime auth reads/writes go through supabaseClient (profiles table).
//
// Prisma 7: connection URLs live in prisma.config.ts (not here).
// DATABASE_URL = transaction pooler (6543) for app runtime
// DIRECT_URL   = session pooler (5432) for migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BudgetOffice
  GovernorOffice
  ProvincialAdministrator
  RecordOffice
}

model Profile {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("profiles")
}

/// Incoming documents logged by Record Office, tracked via transaction code + QR.
model Document {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject         String
  sender          String
  dateReceived    DateTime @map("date_received") @db.Date
  receiverName    String   @map("receiver_name")
  transactionCode String   @unique @map("transaction_code")
  status          String   @default("RECEIVED")
  recordedById    String?  @map("recorded_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([dateReceived])
  @@map("documents")
}
